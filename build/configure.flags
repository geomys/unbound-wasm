--host=wasm32-wasi
--build=x86_64-linux-gnu
--with-libunbound-only
--enable-event-api
--disable-shared
--enable-static
--disable-rpath
--without-pthreads
--without-solaris-threads
--without-ssl
--without-libevent
--disable-dnstap
--disable-dnscrypt
--disable-subnet
--disable-cachedb
--disable-ipsecmod
--disable-ipset
--without-pyunbound
--without-pythonmodule
--disable-gost
--disable-dsa
--disable-ecdsa
--disable-ed25519
--disable-ed448
