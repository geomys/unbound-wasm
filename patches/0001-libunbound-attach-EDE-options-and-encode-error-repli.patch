From 2a87190bf29cb795462e257931fd430d8932db2c Mon Sep 17 00:00:00 2001
From: Filippo Valsorda <hi@filippo.io>
Date: Thu, 23 Jul 2026 01:44:11 +0200
Subject: [PATCH] libunbound: attach EDE options and encode error replies for
 callbacks

mesh_do_callback() differs from mesh_send_reply() in two ways that affect
libunbound API users. First, results delivered with an error rcode reuse
whatever happens to be in the callback buffer, without encoding a reply,
so the answer_packet reaching a ub_resolve_event() callback can be a
stale or unrelated message, such as the response to an internal
sub-query. Second, the EDE EDNS0 options generated under ede: yes are
never attached on this path, so library users cannot observe them.

Mirror mesh_send_reply(): for error rcodes, attach the EDE from the
reply_info and encode a minimal error reply with error_encode(); for
NOERROR answers, attach the EDE when validation failed before encoding.
---
 services/mesh.c | 21 +++++++++++++++++++++
 1 file changed, 21 insertions(+)

diff --git a/services/mesh.c b/services/mesh.c
index 99361b1..8c0ae85 100644
--- a/services/mesh.c
+++ b/services/mesh.c
@@ -1369,6 +1369,16 @@ mesh_do_callback(struct mesh_state* m, int rcode, struct reply_info* rep,
 				&r->edns, NULL, m->s.region, start_time))
 					r->edns.opt_list_inplace_cb_out = NULL;
 		}
+		/* Send along EDE EDNS0 option when SERVFAILing; usually
+		 * DNSSEC validation failures */
+		if(m->s.env->cfg->ede && rep &&
+			rep->reason_bogus != LDNS_EDE_NONE) {
+			edns_opt_list_append_ede(&r->edns.opt_list_out,
+				m->s.region, rep->reason_bogus,
+				rep->reason_bogus_str);
+		}
+		error_encode(r->buf, rcode, &m->s.qinfo, r->qid,
+			r->qflags, &r->edns);
 		fptr_ok(fptr_whitelist_mesh_cb(r->cb));
 		(*r->cb)(r->cb_arg, rcode, r->buf, sec_status_unchecked, NULL,
 			was_ratelimited);
@@ -1382,6 +1392,17 @@ mesh_do_callback(struct mesh_state* m, int rcode, struct reply_info* rep,
 		if(m->s.env->cfg->disable_edns_do && (r->edns.bits&EDNS_DO))
 			r->edns.edns_present = 0;
 
+		/* Attach EDE without SERVFAIL if the validation failed.
+		 * Need to explicitly check for rep->security otherwise failed
+		 * validation paths may attach to a secure answer. */
+		if(m->s.env->cfg->ede && rep &&
+			(rep->security <= sec_status_bogus ||
+			rep->security == sec_status_secure_sentinel_fail) &&
+			rep->reason_bogus != LDNS_EDE_NONE) {
+			edns_opt_list_append_ede(&r->edns.opt_list_out,
+				m->s.region, rep->reason_bogus,
+				rep->reason_bogus_str);
+		}
 		if(!inplace_cb_reply_call(m->s.env, &m->s.qinfo, &m->s, rep,
 			LDNS_RCODE_NOERROR, &r->edns, NULL, m->s.region, start_time) ||
 			!reply_info_answer_encode(&m->s.qinfo, rep, r->qid,
